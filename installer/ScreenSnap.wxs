<?xml version="1.0" encoding="utf-8"?>
<!--
  ScreenSnap MSI installer (WiX v6).

  Per-user install (no admin/UAC) under %LocalAppData%\Programs\ScreenSnap.
  The published, self-contained app folder is harvested wholesale via <Files>.

  Uses the WixToolset.Util.wixext extension for <util:CloseApplication>, so
  the build command must include `-ext WixToolset.Util.wixext`. Pin the
  util extension to the same WiX v6 version (e.g. WixToolset.Util.wixext/6.0.2);
  wildcard refs are rejected and 7.x is incompatible with WiX v6.

  Built from the workflow / locally with:
    wix build installer\ScreenSnap.wxs ^
      -arch <x64|arm64> ^
      -ext WixToolset.Util.wixext ^
      -d PublishDir=<absolute path to publish folder> ^
      -d ProductVersion=<x.y.z> ^
      -d UtilCA=<Wix4UtilCA_X64|Wix4UtilCA_A64> ^
      -o ScreenSnap-<version>-<arch>.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package
    Name="ScreenSnap"
    Manufacturer="Alex Oswald"
    Version="$(var.ProductVersion)"
    UpgradeCode="0C91F1D9-9559-4050-81D3-738DD0D4704F"
    Scope="perUser"
    Compressed="yes"
    Language="1033">

    <!--
      Install the new version first, then remove the old one. Safer than the
      default (afterInstallValidate) because if the new install fails the
      user is left with the previous working version instead of nothing.
    -->
    <MajorUpgrade
      Schedule="afterInstallExecute"
      DowngradeErrorMessage="A newer version of ScreenSnap is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!--
      Politely close a running ScreenSnap.exe before upgrading so the install
      doesn't trip the Windows Installer "files in use" dialog or schedule a
      reboot. CloseMessage/EndSessionMessage send WM_CLOSE/WM_QUERYENDSESSION
      to the app's main window; TerminateProcess="5" force-terminates after
      5 seconds as a fallback if the app doesn't exit on its own.
    -->
    <util:CloseApplication
      Id="CloseScreenSnap"
      Target="ScreenSnap.exe"
      Description="Please close ScreenSnap so the upgrade can continue."
      CloseMessage="yes"
      EndSessionMessage="yes"
      RebootPrompt="no"
      TerminateProcess="5" />

    <!-- Add/Remove Programs metadata -->
    <Icon Id="ScreenSnapIcon" SourceFile="$(var.PublishDir)\ScreenSnap.exe" />
    <Property Id="ARPPRODUCTICON" Value="ScreenSnapIcon" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/alex-oswald/ScreenSnap" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="ARPNOMODIFY" Value="1" />

    <!--
      Launch ScreenSnap.exe at the end of a fresh install / major upgrade.
      Uses WixShellExec from WixUtilExtension. ShellExecute returns
      immediately, so we don't need an async return type; Return="ignore"
      keeps the install successful even if the launch itself fails (e.g.
      AV blocks it). Condition NOT Installed AND NOT REMOVE skips uninstall
      and the maintenance-mode reconfigure path.
      $(var.UtilCA) is set per-arch by the workflow (Wix4UtilCA_X64 /
      Wix4UtilCA_A64) so the right CustomAction DLL is invoked.

      WixShellExecTarget must be populated at runtime via a type-51
      property-setter CA — populating it at author time with
      [INSTALLFOLDER]... isn't supported (WIX1077).
    -->
    <CustomAction Id="SetWixShellExecTarget"
                  Property="WixShellExecTarget"
                  Value="[INSTALLFOLDER]ScreenSnap.exe" />
    <CustomAction Id="LaunchScreenSnap"
                  BinaryRef="$(var.UtilCA)"
                  DllEntry="WixShellExec"
                  Impersonate="yes"
                  Return="ignore" />
    <InstallExecuteSequence>
      <Custom Action="SetWixShellExecTarget" After="InstallFinalize"
              Condition="NOT Installed AND NOT REMOVE" />
      <Custom Action="LaunchScreenSnap" After="SetWixShellExecTarget"
              Condition="NOT Installed AND NOT REMOVE" />
    </InstallExecuteSequence>

    <!-- Install location: %LocalAppData%\Programs\ScreenSnap -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="ScreenSnap" />
      </Directory>
    </StandardDirectory>

    <!-- Start Menu folder -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="ScreenSnap" />
    </StandardDirectory>

    <Feature Id="Main" Title="ScreenSnap" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <!-- Start Menu shortcut (per-user component, HKCU keypath) -->
    <Component Id="StartMenuShortcut" Directory="AppShortcutFolder">
      <Shortcut Id="AppStartMenuShortcut"
                Name="ScreenSnap"
                Description="Switch between saved display-configuration presets"
                Target="[INSTALLFOLDER]ScreenSnap.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="ScreenSnapIcon" />
      <RemoveFolder Id="RemoveAppShortcutFolder" Directory="AppShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\ScreenSnap" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Package>

  <!-- Harvest the entire published self-contained app folder. -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**" />
    </ComponentGroup>
  </Fragment>
</Wix>
