<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ScreenSnap.Settings.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ScreenSnap">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (matches the 32-px standard title bar described in the
             Windows app title bar design guidance). LeftPaddingColumn / RightPaddingColumn
             are sized in code to match AppWindowTitleBar.{Left,Right}Inset so the icon
             and caption never overlap the system caption buttons. -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="32"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaddingColumn" Width="0" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <ImageIcon x:Name="AppTitleBarIcon"
                       Grid.Column="1"
                       Width="16"
                       Height="16"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center" />

            <TextBlock x:Name="AppTitleBarText"
                       Grid.Column="2"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Text="ScreenSnap" />
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" Padding="16,8,16,16" RowSpacing="12" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left: preset list + toolbar -->
        <Grid Grid.Row="0" Grid.Column="0" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Presets" Style="{StaticResource SubtitleTextBlockStyle}" />

            <ListView Grid.Row="1"
                      ItemsSource="{Binding Presets}"
                      SelectedItem="{Binding Selected, Mode=TwoWay}"
                      BorderThickness="1"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      CornerRadius="6">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6">
                <Button Click="OnAddCurrent" ToolTipService.ToolTip="Capture the current layout as a new preset">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="Add current" />
                    </StackPanel>
                </Button>
                <Button Click="OnDelete" ToolTipService.ToolTip="Delete the selected preset">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                </Button>
                <Button Click="OnMoveUp" ToolTipService.ToolTip="Move up">
                    <FontIcon Glyph="&#xE70E;" FontSize="14" />
                </Button>
                <Button Click="OnMoveDown" ToolTipService.ToolTip="Move down">
                    <FontIcon Glyph="&#xE70D;" FontSize="14" />
                </Button>
            </StackPanel>

            <Border Grid.Row="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <StackPanel Spacing="8">
                    <ToggleSwitch Header="Global hotkeys" IsOn="{Binding HotkeysEnabled, Mode=TwoWay}" />
                    <TextBlock Text="{Binding HotkeyHint}" TextWrapping="Wrap" Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox Content="Ctrl" IsChecked="{Binding ModControl, Mode=TwoWay}" />
                        <CheckBox Content="Alt" IsChecked="{Binding ModAlt, Mode=TwoWay}" />
                        <CheckBox Content="Shift" IsChecked="{Binding ModShift, Mode=TwoWay}" />
                        <CheckBox Content="Win" IsChecked="{Binding ModWin, Mode=TwoWay}" />
                    </StackPanel>
                    <CheckBox Content="Also bind 1–9 to jump to presets" IsChecked="{Binding EnableJumpHotkeys, Mode=TwoWay}" />
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,2,0,2" />
                    <CheckBox Content="Start ScreenSnap when I sign in" IsChecked="{Binding RunAtStartup, Mode=TwoWay}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Right: editor for the selected preset -->
        <ScrollViewer Grid.Row="0" Grid.Column="1">
            <StackPanel Spacing="14" DataContext="{Binding Selected}">
                <TextBox Header="Preset name"
                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="e.g. Desk monitors or TV / gaming" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Monitors" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    <Button Click="OnRecapture" ToolTipService.ToolTip="Replace this preset's monitors with the current layout">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Use current layout" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock TextWrapping="Wrap"
                           Opacity="0.7"
                           Text="Turn a monitor off to disable it in this preset, and mark one monitor as primary. Choose each monitor's resolution and orientation; leave resolution on &quot;Use current resolution&quot; to keep whatever it is already using." />

                <ItemsControl ItemsSource="{Binding Monitors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <ToggleSwitch Header="Enabled" IsOn="{Binding Enabled, Mode=TwoWay}" />
                                        <ToggleSwitch Header="Primary" IsOn="{Binding IsPrimary, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ComboBox Header="Resolution" Width="190"
                                                  ItemsSource="{Binding Resolutions}"
                                                  SelectedItem="{Binding SelectedResolution, Mode=TwoWay}" />
                                        <ComboBox Header="Orientation" Width="190"
                                                  ItemsSource="{Binding Orientations}"
                                                  SelectedItem="{Binding SelectedOrientation, Mode=TwoWay}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Click="OnAbout" ToolTipService.ToolTip="About ScreenSnap">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE946;" FontSize="14" />
                        <TextBlock Text="About" />
                    </StackPanel>
                </Button>
                <Button Click="OnExit" ToolTipService.ToolTip="Quit ScreenSnap">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7E8;" FontSize="14" />
                        <TextBlock Text="Exit" />
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Opacity="0.8" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Click="OnApply" ToolTipService.ToolTip="Apply the selected preset now">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7F4;" FontSize="14" />
                        <TextBlock Text="Apply now" />
                    </StackPanel>
                </Button>
                <Button Content="Save" Click="OnSave" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
        </Grid>
    </Grid>
</Window>
